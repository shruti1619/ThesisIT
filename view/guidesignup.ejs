<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Guide Sign Up - ThesisIT</title> <!-- Changed Title -->
    <link rel="stylesheet" href="/CSS/adminsignup.css"> <!-- Assuming same CSS, change if needed -->
</head>
<body>
    <!-- Logo and Navigation -->
    <header>
        <a href="index.html"> <!-- Link to home or relevant page -->
            <img src="/IMAGES/logo.png" alt="ThesisIT Logo" class="logo">
        </a>
    </header>

    <!-- Sign Up Form -->
    <div class="signup-container">
        <h1>Guide Sign Up</h1> <!-- Changed Heading -->
        <!-- Updated form action and method -->
        <form action="/guide/register" method="POST" onsubmit="return validateForm()">
            <label for="name">Enter your name</label>
            <input type="text" id="name" name="name" placeholder="Enter your full name" required>

            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="Enter your email ID" required>

            <label for="mobile">Mobile No.</label>
            <input type="tel" id="mobile" name="mobile" placeholder="Enter your 10-digit mobile no." maxlength="10" minlength="10" required onkeypress="restrictInput(event)">

            <!-- Replaced Admin Code with Academic Year -->
            <label for="academicYear">Academic Year</label>
            <input type="text" id="academicYear" name="academicYear" placeholder="e.g., 2024-2025" required>

            <hr>

            <label for="username">Enter username</label>
            <input type="text" id="username" name="username" placeholder="Enter your desired username" required>

            <label for="password">Set password</label>
            <input type="password" id="password" name="password" placeholder="Enter password (min. 6 characters)" required>

            <label for="confirm_password">Confirm password</label>
            <input type="password" id="confirm_password" name="confirm_password" placeholder="Confirm your password" required>

            <button type="submit">Create Account</button>
        </form>
        <!-- Updated link to guide sign-in page -->
        <p>Already have an account? <a href="/guide/signin">Sign In</a></p>
    </div>

    <!-- Footer -->
    <footer>
        <div class="footer-left">
            <div class="logo">
                <img src="/IMAGES/white logo.png" alt="Thessit Logo">
            </div>
            <p>"Your Academic Projects, Our Priority"</p>
        </div>

        <div class="footer-middle">
            <h3>QUICK LINKS</h3>
            <ul>
                <li><a href="index.html">Home</a></li>
                <li><a href="aboutus.html">About Us</a></li>
                <li><a href="contact.html">Contact Us</a></li>
                <li><a href="homeFAQ.html">FAQs</a></li>
                <!-- Consider changing this link if needed -->
                <li><a href="/student/register">Student Register</a></li>
                 <li><a href="/guide/register">Guide Register</a></li>
            </ul>
        </div>

        <div class="footer-right">
            <h3>GET IN TOUCH</h3>
            <p>Email: thessisit@gmail.com</p>
        </div>
    </footer>

    <!-- Ensure this JS file exists and handles validation correctly -->
    <script src="/JS/guidesignup.js"></script> <!-- Consider renaming JS file -->
</body>
</html>