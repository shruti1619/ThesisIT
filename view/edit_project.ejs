<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Project Management</title>
  <link rel="stylesheet" href="/CSS/edit_project.css">
</head>
<body>
  <nav class="navbar">
    <h2>Project Management</h2>
  </nav>
  <div class="container">
    <button class="view-project">View Project</button>
    <form id="project-form">
      <div class="form-row">
        <div class="form-group">
          <div class="content">
          <label for="project-title">Project Title</label>
          <div class="input-edit">
            <input type="text" id="project-title" placeholder="Enter project title" required>
            <button type="button" class="edit-button">Edit</button>
            </div>
          </div>
        </div>
        <div class="form-group">
          <div class="content">
          <label for="project-domain">Project Domain</label>
          <div class="input-edit">
            <input type="text" id="project-domain" placeholder="Enter domain" required>
            <button type="button" class="edit-button">Edit</button>
            </div>
          </div>
        </div>
      </div>
      <div class="form-group">
        <label for="project-overview">Project Overview</label>
        <div class="input-edit">
          <textarea id="project-overview" placeholder="Explain in above 500 words" required></textarea>
          <button type="button" class="edit-button">Edit</button>
        </div>
      </div>
      <div class="form-group">
        <label for="problem-statement">Problem Statement</label>
        <div class="input-edit">
          <textarea id="problem-statement" placeholder="Enter problem statement (at least in 100 words)" required></textarea>
          <button type="button" class="edit-button">Edit</button>
        </div>
      </div>
      <div class="upload-section">
        <div class="upload-group">
          <label>Seminar 1 PPT</label>
          <input type="file" required>
        </div>
        <div class="upload-group">
          <label>Project Report</label>
          <input type="file" required>
        </div>
        <div class="upload-group">
          <label>References</label>
          <input type="file" required>
        </div>
        <div class="upload-group">
          <label>Seminar 2 PPT</label>
          <input type="file" required>
        </div>
        <div class="upload-group">
          <label>Demonstration Video</label>
          <input type="file" required>
        </div>
        <div class="upload-group">
          <label>Poster</label>
          <input type="file" required>
        </div>
        <div class="upload-group">
          <label>Seminar 3 PPT</label>
          <input type="file" required>
        </div>
        <div class="upload-group">
          <label>Related Codes</label>
          <input type="file" required>
        </div>
      </div>
      </form>
      <button type="submit" class="submit-button">Submit</button>
    
  </div>
  <script src="/JS/edit_project.JS"></script>
</body>
</html>