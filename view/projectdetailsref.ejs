<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Project Management</title>
  <link rel="stylesheet" href="/CSS/PRviewOverall.css">
</head>
<body>
  <nav class="navbar">
    <h2>Project Refinery</h2>
  </nav>
  <div class="container">
    <% if (project) { %>
      <h1>Project Details</h1>
    <% } else { %>
      <button class="view-project">Add Project</button>
    <% } %>
    <form id="project-form" method="POST" action="/projectref/submit">
      <div class="form-row">
        <div class="form-group">
          <label for="projectTitle">Project Title</label>
          <input type="text" id="projectTitle" name="projectTitle" placeholder="Enter project title" value="<%= project ? project.projectTitle : '' %>" <%= project ? 'readonly' : '' %> required>
        </div>
        <div class="form-group">
          <label for="domain">Domain</label>
          <input type="text" id="domain" name="domain" placeholder="Enter domain" value="<%= project ? project.domain : '' %>" <%= project ? 'readonly' : '' %> required>
        </div>
        <div class="form-group">
          <label for="problemStatement">Problem Statement</label>
          <textarea id="problemStatement" name="problemStatement" placeholder="Enter problem statement" <%= project ? 'readonly' : '' %> required><%= project ? project.problemStatement : '' %></textarea>
        </div>
        <div class="form-group">
          <label for="projectOverview">Project Overview</label>
          <textarea id="projectOverview" name="projectOverview" placeholder="Enter project overview" <%= project ? 'readonly' : '' %> required><%= project ? project.projectOverview : '' %></textarea>
        </div>
        <div class="form-group">
          <label for="limitation">Limitation</label>
          <textarea id="limitation" name="limitation" placeholder="Enter limitations" <%= project ? 'readonly' : '' %> required><%= project ? project.limitation : '' %></textarea>
        </div>
        <div class="form-group">
          <label for="technicalIssues">Technical Issues</label>
          <textarea id="technicalIssues" name="technicalIssues" placeholder="Enter technical issues" <%= project ? 'readonly' : '' %> required><%= project ? project.technicalIssues : '' %></textarea>
        </div>
        <div class="form-group">
          <label for="futureScope">Future Scope</label>
          <textarea id="futureScope" name="futureScope" placeholder="Enter future scope" <%= project ? 'readonly' : '' %> required><%= project ? project.futureScope : '' %></textarea>
        </div>
      </div>
      <% if (!project) { %>
        <button type="submit" class="submit-button">Submit</button>
      <% } %>
    </form>
    <div class="project-details">
      <button class="back-button" onclick="window.history.back()">Back</button>
      <button class="alumni-button" onclick="window.location.href='/projectref/alumni/<%= project.userId %>'">View Alumni</button>
    </div>
  </div>
  <script>
    document.getElementById('project-form').addEventListener('submit', function(event) {
      const fields = ['projectTitle','problemStatement', 'projectOverview', 'limitation', 'futureScope', 'technicalIssues', 'domain'];
      let valid = true;

      fields.forEach(field => {
        const input = document.getElementById(field);
        if (!input.value.trim()) {
          valid = false;
          input.style.borderColor = 'red'; // Highlight empty fields
        } else {
          input.style.borderColor = ''; // Reset border color
        }
      });

      if (!valid) {
        event.preventDefault(); // Prevent form submission if validation fails
        alert('Please fill in all fields.');
      }
    });
  </script>
</body>
</html>