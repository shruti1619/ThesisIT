<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Provide Feedback - Seminar <%= seminarNumber %></title>
    <link href="https://fonts.googleapis.com/css?family=Poppins:400,500,600&display=swap" rel="stylesheet">
    <!-- Link to a shared CSS file or add styles here -->
    <style>
        body { font-family: 'Poppins', sans-serif; margin: 20px; background-color: #f4f7f6; color: #333; }
        .container { max-width: 800px; margin: 20px auto; background: #ffffff; padding: 25px 30px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        h2 { color: #2c3e50; border-bottom: 2px solid #e0e0e0; padding-bottom: 10px; margin-bottom: 20px; font-size: 1.8em; }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; font-weight: 500; color: #555; }
        textarea {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ccc;
            border-radius: 4px;
            min-height: 150px; /* Adjust height as needed */
            box-sizing: border-box; /* Include padding and border in element's total width and height */
            font-family: inherit;
            font-size: 1em;
            line-height: 1.5;
        }
        .button-container { text-align: right; margin-top: 20px; }
        .submit-button, .cancel-link {
            padding: 10px 18px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 1em;
            cursor: pointer;
            transition: background-color 0.3s ease;
            display: inline-block;
        }
        .submit-button {
            background-color: #e67e22; /* Orange */
            color: white;
            border: none;
        }
        .submit-button:hover { background-color: #d35400; }
        .cancel-link {
            background-color: #bdc3c7; /* Gray */
            color: #333;
            margin-right: 10px;
        }
        .cancel-link:hover { background-color: #95a5a6; }
        .group-info { margin-bottom: 20px; font-size: 0.95em; color: #555; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Provide Feedback for Seminar <%= seminarNumber %></h2>

        <div class="group-info">
            <p><strong>Group:</strong> <%= group.groupName %></p>
            <% if (project) { %>
                <p><strong>Project Title:</strong> <%= project.projectTitle %></p>
            <% } %>
        </div>

        <form id="feedbackForm" action="/guide/feedback" method="POST">
            <input type="hidden" name="groupId" value="<%= groupId %>">
            <input type="hidden" name="seminarNumber" value="<%= seminarNumber %>">

            <div class="form-group">
                <label for="feedback">Feedback:</label>
                <textarea id="feedback" name="feedback" placeholder="Enter your feedback for the students regarding Seminar <%= seminarNumber %>..."><%= existingFeedback %></textarea>
            </div>

            <div class="button-container">
                <a href="/guide/view/<%= groupId %>" class="cancel-link">Cancel</a>
                <button type="submit" class="submit-button">Submit Feedback</button>
            </div>
        </form>
    </div>

    <!-- Optional: Add JS for validation or character count -->
    <script>
        // Basic example: You could add character limits or other validation here
        const feedbackForm = document.getElementById('feedbackForm');
        const feedbackTextarea = document.getElementById('feedback');

        feedbackForm.addEventListener('submit', (event) => {
            // Example: Trim whitespace before submitting
            feedbackTextarea.value = feedbackTextarea.value.trim();

            // You could add more complex validation if needed
            // if (feedbackTextarea.value.length === 0) {
            //     alert('Feedback cannot be empty.');
            //     event.preventDefault(); // Prevent form submission
            // }
        });
    </script>
</body>
</html>