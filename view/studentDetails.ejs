<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Details</title>
    <link rel="stylesheet" href="/CSS/studentdetails.css">
</head>
<body>
    <nav class="navbar">
        <h1>Student Details</h1>
        <button class="nav-btn" onclick="window.location.href='/admin/logout'">Logout</button>
    </nav>

   
    <table id="studentDetailsTable">
        <thead>
            <tr>
                <th>Name</th>
                <th>Year</th>
                <th>Academic Year</th>
            </tr>
        </thead>
        <tbody>
            <!-- Student details will be populated here -->
        </tbody>
    </table>
    <div class="admin-actions">
        <button id="markAlumniButton">Mark Final Year Students as Alumni</button>
    </div>
</div>

    <script>
        // Fetch detailed student information via AJAX
        fetch('/admin/student-details')
            .then(response => response.json())
            .then(data => {
                const tableBody = document.querySelector('#studentDetailsTable tbody');
                tableBody.innerHTML = data.map(student => `
                    <tr>
                        <td>${student.name}</td>
                        <td>${student.year}</td>
                        <td>${student.academicYear}</td>
                    </tr>
                `).join('');
            })
            .catch(error => console.error('Error fetching student details:', error));
    </script>
</body>
</html>