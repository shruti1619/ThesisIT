<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ThesisIT - Student Dashboard</title>
    <link rel="stylesheet" href="/CSS/SO.css">
</head>
<body>
    <header class="header">
    
  <!---- Navigation Bar -->
   <nav class="navbar">
        <div class="logo">
           <a href="/Welcome"> <img src="/IMAGES/logo.png" alt="ThesisIT Logo"></a>
        </div>

        <div class="search-bar-container">
            <div class="search-bar-wraper">
      
            <input type="text" placeholder="Search Here" id="search-bar">
            <img src="/IMAGES/Leading-icon.png" class="dropdown-lines" alt="Dropdown Lines">
      
            <ul class="dropdown-menu">
              <span class="close-btn">&times;</span>
              <% if (typeof projectDomains !== 'undefined' && projectDomains.length > 0) { %>
                <% projectDomains.forEach(domain => { %>
                  <% const encodedDomain = encodeURIComponent(domain); %>
                  <%# Prepend /student/ to the href %>
                  <li><a href="/student/projects/domain/<%= encodedDomain %>"><%= domain %></a></li>
                <% }); %>
              <% } else { %>
                <li><a href="#">No domains found</a></li>
              <% } %>
            </ul>
            <!-- === End Modified Dropdown Menu === -->
      
            <img src="/IMAGES/search bar.png" class="search-icon" alt="Search Icon">
          </div>
            </div>
           </div>
        <div class="nav-icons">
            <ul>
                <a href="/api/juniorfaq"><img src="/IMAGES/FAQ.png" alt="faq"></a>
                <a href="#"><img src="/IMAGES/noti.png" alt="vector"></a>
                <a href="/student/profile"> <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="black" class="bi bi-person-square" viewBox="0 0 16 16">
                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                    <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1v-1c0-1-1-4-6-4s-6 3-6 4v1a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1z"/>
                  </svg>
                </a>
                
            </ul>

        </div>
    </nav>
    </header>

    <!-- Main Content -->
    <div class="main-content">
        <h1>Student Dashboard</h1>
        <div class="dashboard-options">
            <div class="option">
                <h2>Project Hub  
                <span>  <a href="/projecthub/"><img src="/IMAGES/PH.png"></a></span>
                </h2>
                <p>Check what your seniors did in their final year</p>
                
            </div>
            <div class="option">
                <h2>Project Refinery       
                     <span><a href="/projectref/"><img src="/IMAGES/PR.png"></a></span> 
                    </h2>
                  <p>Check something which you can complete</p>
               
            </div>
        </div>
    </div>

    <!-- Footer Section -->
    <footer>
        <div class="footer-left">
            <div class="logo"> 
                <img src="/IMAGES/white logo.png" alt="Thessit Logo">
            </div>
            <p>"Your Academic Projects, Our Priority"</p>
        </div>

        <div class="footer-middle">
            <h3>QUICK LINKS</h3>
            <ul>
                <li><a href="/Welcome">Home</a></li>
                <li><a href="/api/aboutus">About Us</a></li>
                <li><a href="/api/contact">Contact Us</a></li>
                <li><a href="/api/homefaq">FAQs</a></li>
                <li><a href="/api/option">Register</a></li>
            </ul>
        </div>

        <div class="footer-right">
            <h3>GET IN TOUCH</h3>
            <p>Email: thessisit@gmail.com</p>
        </div>
    </footer>
    <script src="/JS/SO.js"></script>

</body>
</html>